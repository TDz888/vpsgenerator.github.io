{
  "version": 2,
  "functions": {
    "api/vpsuser.js": {
      "runtime": "nodejs18.x"
    }
  },
  "builds": [
    { "src": "api/vpsuser.js", "use": "@vercel/node" },
    { "src": "public/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/vpsuser.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
